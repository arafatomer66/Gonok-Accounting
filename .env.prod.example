NODE_ENV=production
PORT=3333

# Domain for Caddy HTTPS (sslip.io for IP-based auto-HTTPS)
DOMAIN=13-234-68-147.sslip.io

# PostgreSQL (use service name 'postgres' as host in Docker network)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=gonok
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=gonok
DB_SYNC=true  # Set true on first deploy to create tables, then change to false

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_RANDOM_64_CHAR_STRING
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# CouchDB (use service name 'couchdb' as host in Docker network)
COUCHDB_URL=http://couchdb:5984
COUCHDB_PUBLIC_URL=http://YOUR_DOMAIN_OR_IP/couchdb
COUCHDB_USERNAME=admin
COUCHDB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# PostgreSQL container env
POSTGRES_USER=gonok
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=gonok
